class Solution {
    public List<Integer> findDisappearedNumbers(int[] nums) {
        HashSet<Integer>num=new HashSet<>();
        List<Integer> res= new ArrayList<>();
        for(int r=0;r<nums.length;r++){
            num.add(nums[r]);
        }
        for(int r=1;r<nums.length+1;r++){
            if(!num.contains(r)){
                res.add(r);
            }

        }
        return res;
    }
}
