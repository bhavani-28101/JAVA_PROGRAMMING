//using set
class Solution {
    public int maximumUniqueSubarray(int[] nums) {
        int l=0;
        int total=0;
        int res=0;
        Set<Integer> s=new HashSet<>();
        for(int r=0;r<nums.length;r++){
            while(s.contains(nums[r])){
                s.remove(nums[l]);
                total-=nums[l];
                l+=1;
            }
            s.add(nums[r]);
            total+=nums[r];
            res=Math.max(res,total);
        }
        return res;
    }
}
