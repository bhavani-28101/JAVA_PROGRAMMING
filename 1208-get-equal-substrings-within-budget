class Solution {
    public int equalSubstring(String s, String t, int maxCost) {
        int l=0;
        int res=0;
        int total=0;
        for(int r=0;r<s.length();r++){
            total+=Math.abs(s.charAt(r)-t.charAt(r));
            while(total>maxCost){
                total-=Math.abs(s.charAt(l)-t.charAt(l));
                l+=1;
            }
            res=Math.max(res,r-l+1);

        }
        return res;
    }
}
