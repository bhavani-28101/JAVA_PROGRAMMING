class Solution {
    public int majorityElement(int[] nums) {
        Map<Integer,Integer>dict=new HashMap<>();
        int res=0;
        int mainres=Integer.MIN_VALUE;
        int freq=0;
        for(int i=0;i<nums.length;i++){
            dict.put(nums[i],dict.getOrDefault(nums[i],0)+1);
            freq=dict.get(nums[i]);
            if(freq>res){
                res=freq;
                mainres=nums[i];
            }
        }
        return mainres;   
    }
}
