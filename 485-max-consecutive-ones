class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int best=0;
        int count=0;
        for(int r=0;r<nums.length;r++){
            if(nums[r]==1){
                count+=1;
            }
            else{
                best=Math.max(best,count);
                count=0;
            }
        }
        return Math.max(best,count);
    }
}
