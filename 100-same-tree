class Solution {
    public boolean isSameTree(TreeNode p, TreeNode q) {
        boolean l;
        boolean r;
        if ((p == null) && (q == null)){
            return true;
        }
        if( (p == null) || (q == null)){
            return false;
        }
        if (p.val!=q.val){
            return false;
        }
        l=isSameTree(p.left,q.left);
        r=isSameTree(p.right,q.right);
        return l && r;
    }
}
