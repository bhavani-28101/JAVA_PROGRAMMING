class Solution {
    public int longestSubarray(int[] nums){
        int res=0;
        int l=0;
        int zero=0;
        for(int r=0;r<nums.length;r++){
            if(nums[r]==0){
                zero+=1;
            }
            while(zero>1){
                if(nums[l]==0)
                    zero-=1;
                l+=1;
            }
            res=Math.max(res,r-l);
        }
        if(zero==0){
            return nums.length-1;
        }
        return res;

    }
}
