class Solution {
    public boolean isGood(int[] nums) {
        Arrays.sort(nums);
        
        int n = nums[nums.length - 1]; // max element
        
        // check length
        if (nums.length != n + 1) return false;
        
        // check 1 to n-1
        for (int i = 0; i < n - 1; i++) {
            if (nums[i] != i + 1) return false;
        }
        
        // check last two elements are n
        return nums[n - 1] == n && nums[n] == n;
    }
}
