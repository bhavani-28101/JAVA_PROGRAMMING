class Solution {
    public int singleNumber(int[] nums) {
        int res=0;
        Map<Integer,Integer>dict=new HashMap<>();
        for(int r=0;r<nums.length;r++){
            dict.put(nums[r],dict.getOrDefault(nums[r],0)+1);
        }
        for(Map.Entry<Integer, Integer> entry: dict.entrySet()) {
            if(entry.getValue() == 1) {
                res=entry.getKey();
        }
        }
        return res;
}
}
