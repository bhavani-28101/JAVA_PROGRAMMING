class Solution {
    public int longestOnes(int[] nums, int k) {
        int l=0;
        int res=0;
        int zero=0;
        for(int r=0;r<nums.length;r++){
            if(nums[r]==0){
                zero+=1;
            }
            while(zero>k){
                if(nums[l]==0)
                    zero-=1;
                l+=1;
            }
            res=Math.max(res,r-l+1);
        }
        return res;
    }
}
