class Solution {
    public int maxProfit(int[] prices) {
        int buy=Integer.MAX_VALUE;
        int sellprofit=0;
        for(int i=0;i<prices.length;i++){
            if(prices[i]<buy){
                buy=prices[i];
            }
            else{
                sellprofit=Math.max(sellprofit,prices[i]-buy);
            }
        }
        return sellprofit;
    }
}
